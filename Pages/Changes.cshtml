@page
@using Microsoft.AspNetCore.Http.Features
@model ProgramChangeTracker.Pages.ChangesModel

<h1>Program Changes</h1>

@if (Model.Items.Count == 0){
    <p>No change requests yet.</p>
}
else{
    <ul>
        @foreach (var item in Model.Items){
            <li>
                #@item.Id - <strong>@item.Title</strong> (@item.Status)
                <form method="post" asp-page-handler="Close" style="display:inline;">
                    <input type="hidden" name="Id" value="@item.Id" />
                    <button type="submit">Close</button>
                </form>
                <div>@item.Description</div>
            </li>
        }
    </ul>
}

<form method="post" asp-page-handler="Close">
    <label>Title</label><br />
    <input name="Title" /><br />
    <label>Description</label><br />
    <textarea name = "Description"></textarea><br />
    <button type="submit">Add</button>
</form>

<hr />