@page
@using Microsoft.AspNetCore.Http.Features
@model ProgramChangeTracker.Pages.ChangesModel
@using ProgramChangeTracker.Models

<h1>Program Changes</h1>

@if (Model.Items.Count == 0){
    <p>No change requests yet.</p>
}
else{
    <ul>
        @foreach (var item in Model.Items){
            <li>
                #@item.Id - <strong>@item.Title</strong> (@item.Status)
                
                <form method="post" asp-page-handler="UpdateStatus" style="display:inline;">
                    <input type="hidden" name="Id" value="@item.Id" />
                    @{
                        var openSelected = item.Status == ChangeStatus.Open ? "selected" : "";
                        var reviewSelected = item.Status == ChangeStatus.InReview ? "selected" : "";
                        var closedSelected = item.Status == ChangeStatus.Closed ? "selected" : "";
                    }
                    <select name="Status" onchange="this.form.submit()">
                        <option value="" enabled>Select...</option>
                        <option value="Open" openSelected>Open</option>
                        <option value="InReview" reviewSelected>In Review</option>
                        <option value="Closed" closedSelected>Closed</option>
                    </select>
                </form>
                <div>@item.Description</div>
                <div><small>Updated: @item.UpdatedAt.ToString("u")</small></div>
            </li>
        }
    </ul>
}

<form method="post">
    <label>Title</label><br />
    <input name="Title" /><br />
    <label>Description</label><br />
    <textarea name = "Description"></textarea><br />
    <button type="submit">Add</button>
</form>

<hr />
